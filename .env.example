CINEFORGE_ENV=local
CINEFORGE_LOG_LEVEL=INFO
CINEFORGE_DATABASE_URL=sqlite:///./storage/cineforge_local.db
CINEFORGE_COMFYUI_BASE_URL=http://127.0.0.1:8188
CINEFORGE_STORAGE_ROOT=./storage
CINEFORGE_ALLOW_ABSOLUTE_INPUT_PATHS=false
CINEFORGE_QUEUE_WORKER_ENABLED=false
CINEFORGE_AUTONOMY_MODE=scaffold_only
CINEFORGE_CORS_ALLOWED_ORIGINS=["http://127.0.0.1:5173","http://localhost:5173"]

